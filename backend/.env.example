# Required
JWT_SECRET=your-random-secret-here
ADMIN_TOKEN=your-admin-token-here

# Optional
PORT=3001
INVITE_CODE=letmein2024
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
CORS_ORIGINS=http://localhost:5173
DEMO_ENABLED=true

# Web Push (generate with: node -e "const w=require('web-push');console.log(JSON.stringify(w.generateVAPIDKeys()))")
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@lifechat.local

# Federation
FEDERATION_ENABLED=true
FEDERATION_DOMAIN=localhost
FEDERATION_NAME=LifeChat
SEED_PEERS=
